# LifePilot local development example values.
# Do not put real secrets in this file.

MYSQL_DATABASE=lifepilot
MYSQL_USER=lifepilot
MYSQL_PASSWORD=lifepilot_dev_password
MYSQL_ROOT_PASSWORD=lifepilot_root_password
MYSQL_PORT=3306

BACKEND_PORT=8080
FRONTEND_PORT=5173

JWT_SECRET=change-me-in-local-env-only
JWT_EXPIRATION_MINUTES=120

AI_PROVIDER=mock
AI_API_BASE_URL=
AI_API_KEY=

